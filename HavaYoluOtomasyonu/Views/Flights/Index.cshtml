@model IEnumerable<HavaYoluOtomasyonu.Models.Flight>

@{
    ViewData["Title"] = "Uçuşlar";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3">Uçuşlar</h1>
        <p class="text-muted-small mb-0">Mevcut uçuşları inceleyin.</p>
    </div>
    
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-primary btn-lg">Yeni Uçuş Ekle</a>
    }
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Gidiş</th>
                        <th>Varış</th>
                        <th>Durum</th>
                        <th>Uçak</th>
                        <th>Rota</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th class="text-end">İşlemler</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.DepartureTime)</td>
                            <td>@Html.DisplayFor(modelItem => item.ArrivalTime)</td>
                            <td>@Html.DisplayFor(modelItem => item.FlightStatus)</td>
                            <td>@(item.Aircraft?.TailNumber ?? item.AircraftId.ToString())</td>
                            <td>@(item.Routes != null ? (item.Routes.DepartureAirport?.City + " → " + item.Routes.ArrivalAirport?.City) : item.RoutesId.ToString())</td>
                        
                            @if (User.IsInRole("Admin"))
                            {
                                <td class="table-actions text-end">
                                    <a asp-action="Details" asp-route-id="@item.FlightId" class="btn btn-outline-info btn-sm">Detay</a>
                                    <a asp-action="Edit" asp-route-id="@item.FlightId" class="btn btn-outline-primary btn-sm">Düzenle</a>
                                    <a asp-action="Delete" asp-route-id="@item.FlightId" class="btn btn-outline-danger btn-sm">Sil</a>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>