@model HavaYoluOtomasyonu.Models.Flight

@{
    ViewData["Title"] = "Yeni Uçuş";
}

<div class="page-header">
    <div>
        <h1 class="h3">Yeni Uçuş Oluştur</h1>
        <p class="text-muted-small mb-0">Yeni bir uçuş kaydı ekleyin ve uçuş planını düzenleyin.</p>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title mb-4">Uçuş Bilgileri</h5>
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="RoutesId" class="form-label"></label>
                        <select asp-for="RoutesId" class="form-control" asp-items="ViewBag.RoutesId"></select>
                        <span asp-validation-for="RoutesId" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="AircraftId" class="form-label"></label>
                        <select asp-for="AircraftId" class="form-control" asp-items="ViewBag.AircraftId"></select>
                        <span asp-validation-for="AircraftId" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="DepartureTime" class="form-label"></label>
                        <input asp-for="DepartureTime" class="form-control" />
                        <span asp-validation-for="DepartureTime" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="ArrivalTime" class="form-label"></label>
                        <input asp-for="ArrivalTime" class="form-control" />
                        <span asp-validation-for="ArrivalTime" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-12">
                    <div class="form-group">
                        <label asp-for="FlightStatus" class="form-label"></label>
                        <input asp-for="FlightStatus" class="form-control" />
                        <span asp-validation-for="FlightStatus" class="text-danger"></span>
                    </div>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-success">Kaydet</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Geri Dön</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
