@model IEnumerable<HavaYoluOtomasyonu.Models.Ticket>

@{
    ViewData["Title"] = "Bilet İşlemleri";
}

<div class="page-header">
    <div>
        <h1 class="h3">Bilet İşlemleri</h1>
        <p class="text-muted-small mb-0">Tüm bilet kayıtlarını burada görüntüleyebilir, düzenleyebilir veya inceleyebilirsiniz.</p>
    </div>
    <a asp-action="Create" class="btn btn-success btn-lg">Yeni Bilet Oluştur</a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Bilet No</th>
                        <th>Yolcu</th>
                        <th>Uçuş</th>
                        <th>Koltuk</th>
                        <th>Sınıf</th>
                        <th>Check-in</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.TicketNumber</td>
                            <td>@item.Passenger?.FirstName @item.Passenger?.LastName</td>
                            <td>@item.Flight?.FlightId</td>
                            <td>@item.SeatNumber</td>
                            <td>@item.ClassType</td>
                            <td>
                                @if (item.IsCheckedIn == true)
                                {
                                    <span class="badge bg-success">Tamamlandı</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Beklemede</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.TicketId" class="btn btn-outline-info btn-sm">Detay</a>
                                <a asp-action="Edit" asp-route-id="@item.TicketId" class="btn btn-outline-primary btn-sm">Düzenle</a>
                                <a asp-action="Delete" asp-route-id="@item.TicketId" class="btn btn-outline-danger btn-sm">Sil</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
