@model IEnumerable<HavaYoluOtomasyonu.Models.Ticket>

@{
    ViewData["Title"] = "Bilet İşlemleri";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3" style="color: #0A2342; font-weight: bold;">🎟️ Bilet İşlemleri</h1>
        <p class="text-muted mb-0">Mevcut biletlerinizi inceleyin veya yeni bir uçuş seçerek seyahatinizi planlayın.</p>
    </div>
    
    @if (User.IsInRole("Admin") || User.IsInRole("YerHizmetleri"))
    {
        <a asp-action="Create" class="btn btn-success btn-lg">Yeni Bilet Oluştur</a>
    }
</div>

@if (Model != null && Model.Any())
{
    <div class="card shadow-sm mb-5">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Bilet No</th>
                            <th>Yolcu</th>
                            <th>Uçuş No</th>
                            <th>Koltuk</th>
                            <th>Sınıf</th>
                            <th>Check-in</th>
                            @if (User.IsInRole("Admin"))
                            {
                                <th class="text-end">İşlemler</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.TicketNumber</td>
                                <td>@item.Passenger?.FirstName @item.Passenger?.LastName</td>
                                <td><span class="badge bg-secondary">#@item.Flight?.FlightId</span></td>
                                <td>@item.SeatNumber</td>
                                <td>@item.ClassType</td>
                                <td>
                                    @if (item.IsCheckedIn == true)
                                    {
                                        <span class="badge bg-success">Tamamlandı</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Beklemede</span>
                                    }
                                </td>
                                @if (User.IsInRole("Admin"))
                                {
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@item.TicketId" class="btn btn-outline-info btn-sm">Detay</a>
                                        <a asp-action="Edit" asp-route-id="@item.TicketId" class="btn btn-outline-primary btn-sm">Düzenle</a>
                                        <a asp-action="Delete" asp-route-id="@item.TicketId" class="btn btn-outline-danger btn-sm">Sil</a>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info p-4 text-center shadow-sm mb-5" style="border-radius: 12px; border-left: 5px solid #0A2342;">
        <h4 class="fw-bold text-dark">Henüz kayıtlı bir biletiniz bulunmuyor.</h4>
        <p class="text-muted mb-0">Aşağıdaki güncel uçuş listesinden dilediğiniz rotayı seçerek hemen yeni bir bilet oluşturabilirsiniz.</p>
    </div>
}

<div class="mt-5 pt-2 mb-5">
    <div class="mb-4">
        <h3 class="fw-bold" style="color: #0A2342;">✈️ Seyahatinizi Planlayın: Güncel Uçuşlar</h3>
        <p class="text-muted">AeroSys güvencesiyle en yakın tarihteki aktif uçuş seferlerimiz.</p>
    </div>

    <div class="row g-4">
        @if (ViewBag.YaklasanUcuslar != null)
        {
            foreach (var ucus in ViewBag.YaklasanUcuslar)
            {
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm border-0 flight-vitrin-card" style="border-radius: 12px; transition: transform 0.3s;">
                        
                        <div class="bg-light text-center py-3 border-bottom" style="border-top-left-radius: 12px; border-top-right-radius: 12px;">
                            <span class="text-danger fw-bold">📅 @ucus.DepartureTime.ToString("dd MMMM yyyy - HH:mm")</span>
                        </div>
                        
                        <div class="card-body text-center d-flex flex-column justify-content-center p-4">
                            <h5 class="card-title fw-bold mb-3" style="color: #0A2342; font-size: 1.2rem;">
                                @(ucus.Routes?.DepartureAirport?.City)
                                <span class="text-danger mx-2">➔</span>
                                @(ucus.Routes?.ArrivalAirport?.City)
                            </h5>
                            
                            <p class="card-text text-muted mb-4">Uçuş Seferi: <span class="fw-bold">#@ucus.FlightId</span></p>
                            
                            @if (User.Identity != null && User.Identity.IsAuthenticated)
                            {
                                <a href="/Tickets/Create?flightId=@ucus.FlightId" class="btn btn-outline-danger w-100 mt-auto fw-bold" style="border-radius: 25px;">
                                    BU UÇUŞA BİLET AL
                                </a>
                            }
                            else
                            {
                                <a href="/Home/Login" class="btn btn-outline-danger w-100 mt-auto fw-bold" style="border-radius: 25px;">
                                    GİRİŞ YAP VE BİLET AL
                                </a>
                            }
                        </div>
                        
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    .flight-vitrin-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.15) !important;
    }
</style>