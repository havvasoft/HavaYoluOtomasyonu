@model IEnumerable<HavaYoluOtomasyonu.Models.Staff>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.FirstName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LastName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Phone)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Password)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.HireDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RoleId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EmploymentStatus)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Bookings)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FlightCrews)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MaintenanceLogs)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Role)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TechnicalCertifications)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.FirstName)
            </td>
            <td>
                @Html.DisplayFor(model => item.LastName)
            </td>
            <td>
                @Html.DisplayFor(model => item.Email)
            </td>
            <td>
                @Html.DisplayFor(model => item.Phone)
            </td>
            <td>
                @Html.DisplayFor(model => item.Password)
            </td>
            <td>
                @Html.DisplayFor(model => item.HireDate)
            </td>
            <td>
                @Html.DisplayFor(model => item.RoleId)
            </td>
            <td>
                @Html.DisplayFor(model => item.EmploymentStatus)
            </td>
            <td>
                @Html.DisplayFor(model => item.Bookings)
            </td>
            <td>
                @Html.DisplayFor(model => item.FlightCrews)
            </td>
            <td>
                @Html.DisplayFor(model => item.MaintenanceLogs)
            </td>
            <td>
                @Html.DisplayFor(model => item.Role)
            </td>
            <td>
                @Html.DisplayFor(model => item.TechnicalCertifications)
            </td>
                <td class="text-end">
                    <a asp-controller="Staffs" asp-action="Edit" asp-route-id="@item.StaffId" class="btn btn-sm btn-warning fw-bold">✏️ Düzenle</a>
                    <a asp-controller="Staffs" asp-action="Details" asp-route-id="@item.StaffId" class="btn btn-sm btn-info fw-bold text-white">🔍 Detay</a>
                    <a asp-controller="Staffs" asp-action="Delete" asp-route-id="@item.StaffId" class="btn btn-sm btn-danger fw-bold">🗑️ Sil</a>
                </td>
        </tr>
}
    </tbody>
</table>
