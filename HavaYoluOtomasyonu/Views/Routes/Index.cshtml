@model IEnumerable<HavaYoluOtomasyonu.Models.Route>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Distance)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EstimatedDuration)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ArrivalAirport)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.DepartureAirport)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Distance)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EstimatedDuration)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ArrivalAirport.AirportId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.DepartureAirport.AirportId)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.RoutesId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.RoutesId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.RoutesId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
