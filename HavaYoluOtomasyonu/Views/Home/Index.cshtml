@{
    ViewData["Title"] = "Ana Sayfa";
}

<style>
    .hero-section {
        background-image: linear-gradient(rgba(10, 35, 66, 0.7), rgba(10, 35, 66, 0.7)), url('https://images.unsplash.com/photo-1436491865332-7a61a109cc05?q=80&w=2074&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-top: -17px;
    }

    .flight-search-card {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 12px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.4);
        padding: 35px;
        border-top: 5px solid #E20000;
        width: 100%;
    }

    .btn-thy {
        background-color: #E20000;
        color: white;
        font-weight: bold;
        transition: all 0.3s ease;
        height: 100%; 
    }

        .btn-thy:hover {
            background-color: #B30000;
            color: white;
            transform: translateY(-2px);
        }
</style>

<div class="hero-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-11">
                
                <div class="text-center text-white mb-5">
                    <h1 class="display-4 fw-bold">Dünyayı Keşfetmeye Hazır Mısınız?</h1>
                    <p class="lead">AeroSys ile yüzlerce destinasyon tek tık uzağınızda.</p>
                </div>

                <div class="flight-search-card">
                    <form action="/Flights" method="get">
                        <div class="row g-3">
                            
                            <div class="col-md-3">
                                <label class="form-label text-muted fw-bold">Nereden</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white">🛫</span>
                                    <select class="form-select border-start-0" name="neredenId" required>
                                        <option value="">Şehir veya Havalimanı Seçin</option>
                                        @if (ViewBag.Havalimanlari != null)
                                        {
                                            foreach (var airport in ViewBag.Havalimanlari)
                                            {
                                                <option value="@airport.AirportId">@airport.City - @airport.AirportName</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label text-muted fw-bold">Nereye</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white">🛬</span>
                                    <select class="form-select border-start-0" name="nereyeId" required>
                                        <option value="">Şehir veya Havalimanı Seçin</option>
                                        @if (ViewBag.Havalimanlari != null)
                                        {
                                            foreach (var airport in ViewBag.Havalimanlari)
                                            {
                                                <option value="@airport.AirportId">@airport.City - @airport.AirportName</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label text-muted fw-bold">Gidiş Tarihi</label>
                                <input type="date" class="form-control" required>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label d-none d-md-block">&nbsp;</label>
                                <button type="submit" class="btn btn-thy w-100 py-2">
                                    UÇUŞ ARA ✈️
                                </button>
                            </div>

                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
