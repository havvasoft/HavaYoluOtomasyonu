@{
    ViewData["Title"] = "Yönetim Paneli";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-5 p-4 bg-white shadow-sm" style="border-radius: 12px; border-left: 5px solid #0A2342;">
        <div>
            <h1 class="h3 mb-1 fw-bold" style="color: #0A2342;">✈️ AeroSys Kontrol Merkezi</h1>
            <p class="text-muted mb-0">Sistem verilerini yönetmek, bilet ve uçuş kayıtlarını incelemek için aşağıdaki panelleri kullanabilirsiniz.</p>
        </div>
        <div class="text-end">
            <span class="badge bg-danger p-2 fs-6">Yetki: @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
        </div>
    </div>

    <div class="row g-4">
        
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 menu-card">
                <div class="card-body text-center p-4">
                    <div class="fs-1 mb-3">🛫</div>
                    <h4 class="fw-bold" style="color: #0A2342;">Uçuş Seferleri</h4>
                    <p class="text-muted small">Yeni uçuş ekleme, rota tanımlama ve aktif sefer listesini yönetme ekranı.</p>
                    <a href="/Flights/Index" class="btn btn-outline-primary w-100 stretched-link fw-bold" style="border-radius: 20px;">Uçuşları Yönet</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 menu-card">
                <div class="card-body text-center p-4">
                    <div class="fs-1 mb-3">🎟️</div>
                    <h4 class="fw-bold" style="color: #0A2342;">Bilet Kayıtları</h4>
                    <p class="text-muted small">Satış yapılan tüm biletleri listeleme, check-in durumları ve iptal işlemleri.</p>
                    <a href="/Tickets/Index" class="btn btn-outline-primary w-100 stretched-link fw-bold" style="border-radius: 20px;">Biletleri Yönet</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 menu-card">
                <div class="card-body text-center p-4">
                    <div class="fs-1 mb-3">👥</div>
                    <h4 class="fw-bold" style="color: #0A2342;">Yolcu Bilgileri</h4>
                    <p class="text-muted small">Sisteme kayıtlı tüm yolcuların (müşterilerin) iletişim ve pasaport detayları.</p>
                    <a href="/Passengers/Index" class="btn btn-outline-primary w-100 stretched-link fw-bold" style="border-radius: 20px;">Yolcuları İncele</a>
                </div>
            </div>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0 menu-card" style="border-top: 3px solid #E20000;">
                    <div class="card-body text-center p-4">
                        <div class="fs-1 mb-3">🏢</div>
                        <h4 class="fw-bold text-danger">Personel (Staff) Kadrosu</h4>
                        <p class="text-muted small">Şirket çalışanları, işe alım tarihleri ve iletişim kayıtlarının yönetimi.</p>
                        <a href="/Staffs/Index" class="btn btn-danger w-100 stretched-link fw-bold" style="border-radius: 20px;">Personeli Yönet</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0 menu-card" style="border-top: 3px solid #E20000;">
                    <div class="card-body text-center p-4">
                        <div class="fs-1 mb-3">🌍</div>
                        <h4 class="fw-bold text-danger">Havalimanı Tanımları</h4>
                        <p class="text-muted small">Sistemdeki aktif havalimanları, şehir kodları ve pist koordinatları.</p>
                        <a href="/Airports/Index" class="btn btn-danger w-100 stretched-link fw-bold" style="border-radius: 20px;">Havalimanlarını Yönet</a>
                    </div>
                </div>
            </div>
        }

    </div>
</div>

<style>
    /* Kartların üzerine gelince büyüme ve havaya kalkma efekti */
    .menu-card {
        border-radius: 15px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .menu-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 25px rgba(0,0,0,0.15) !important;
    }
</style>