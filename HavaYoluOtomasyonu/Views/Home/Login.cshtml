@{
    ViewData["Title"] = "Sisteme Giriş";
}

<style>
    .login-container {
        min-height: 75vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #f4f6f9; /* Açık gri, göz yormayan arka plan */
        margin-top: 20px;
    }

    .login-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.15);
        overflow: hidden;
        width: 100%;
        max-width: 900px;
    }

    .login-sidebar {
        background-color: #0A2342; /* Havacılık Mavisi */
        color: white;
        padding: 50px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .login-form-area {
        padding: 50px;
    }

    .btn-login {
        background-color: #E20000; /* Vurgulu Kırmızı */
        color: white;
        font-weight: bold;
        border-radius: 25px;
        padding: 12px;
        letter-spacing: 1px;
        transition: all 0.3s ease;
    }

        .btn-login:hover {
            background-color: #B30000;
            color: white;
            transform: translateY(-2px);
        }

    .form-control {
        padding: 10px 15px;
    }

        .form-control:focus {
            border-color: #0A2342;
            box-shadow: 0 0 0 0.25rem rgba(10, 35, 66, 0.15);
        }
</style>

<div class="login-container">
    <div class="login-card row g-0">
        
        <!-- Sol Bilgi Paneli -->
        <div class="col-md-5 login-sidebar text-center">
            <h2 class="fw-bold mb-4">Aero<span style="color: #E20000;">Sys</span></h2>
            <p class="lead" style="font-size: 1.1rem;">Değerli Yolcularımız ve Çalışanlarımız,<br><br>Gelişmiş otomasyon sistemimize güvenle giriş yapabilirsiniz.</p>
            <div class="mt-4" style="font-size: 4rem;">✈️</div>
        </div>

        <!-- Sağ Form Paneli -->
        <div class="col-md-7 login-form-area">
            <h3 class="fw-bold mb-4" style="color: #0A2342;">Sisteme Giriş</h3>
            
            <form action="#" method="post">
                <!-- Kullanıcı Adı / E-posta -->
                <div class="mb-4">
                    <label class="form-label text-muted fw-bold">E-posta veya Sicil Numaranız</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">📧</span>
                        <input type="text" class="form-control border-start-0" placeholder="Örn: ornek@mail.com" required>
                    </div>
                </div>

                <!-- Şifre -->
                <div class="mb-4">
                    <label class="form-label text-muted fw-bold">Şifre</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">🔒</span>
                        <input type="password" class="form-control border-start-0" placeholder="••••••••" required>
                    </div>
                </div>

                <!-- Şifremi Unuttum & Beni Hatırla -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="rememberMe">
                        <label class="form-check-label text-muted" for="rememberMe">Beni Hatırla</label>
                    </div>
                    <a href="#" class="text-decoration-none fw-bold" style="color: #E20000;">Şifremi Unuttum</a>
                </div>

                <!-- Giriş Butonu -->
                <button type="submit" class="btn btn-login w-100 mb-4">SİSTEME GİRİŞ YAP</button>
                
                <div class="text-center">
                    <span class="text-muted">Henüz hesabınız yok mu?</span>
                    <a href="#" class="text-decoration-none fw-bold ms-1" style="color: #0A2342;">Hemen Kayıt Olun</a>
                </div>
            </form>
        </div>

    </div>
</div>