@model HavaYoluOtomasyonu.Models.LoginViewModel

@{
    ViewData["Title"] = "Sisteme Giriş";
}

<style>
    .login-container {
        min-height: 75vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #f4f6f9;
        margin-top: 20px;
    }

    .login-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.15);
        overflow: hidden;
        width: 100%;
        max-width: 900px;
    }

    .login-sidebar {
        background-color: #0A2342;
        color: white;
        padding: 50px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .login-form-area {
        padding: 50px;
    }

    .btn-login {
        background-color: #E20000;
        color: white;
        font-weight: bold;
        border-radius: 25px;
        padding: 12px;
        letter-spacing: 1px;
        transition: all 0.3s ease;
    }

    .btn-login:hover {
        background-color: #B30000;
        color: white;
        transform: translateY(-2px);
    }

    .form-control {
        padding: 10px 15px;
    }

    .form-control:focus {
        border-color: #0A2342;
        box-shadow: 0 0 0 0.25rem rgba(10, 35, 66, 0.15);
    }
</style>

<div class="login-container">
    <div class="login-card row g-0">
        
        <!-- Sol Bilgi Paneli -->
        <div class="col-md-5 login-sidebar text-center">
            <h2 class="fw-bold mb-4">Aero<span style="color: #E20000;">Sys</span></h2>
            <p class="lead" style="font-size: 1.1rem;">Değerli Yolcularımız ve Çalışanlarımız,<br><br>Gelişmiş otomasyon sistemimize güvenle giriş yapabilirsiniz.</p>
            <div class="mt-4" style="font-size: 4rem;">✈️</div>
        </div>

        <!-- Sağ Form Paneli -->
        <div class="col-md-7 login-form-area">
            <h3 class="fw-bold mb-4" style="color: #0A2342;">Sisteme Giriş</h3>

            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3 text-start">
                    <label class="form-label text-muted fw-bold">Giriş Türü Seçiniz</label>
                    <select name="UserType" class="form-select border-start-0" required style="border-radius: 8px;">
                        <option value="Admin">👑 Sistem Yöneticisi (Admin)</option>
                        <option value="Staff">🏢 Personel (Yer Hizmetleri vb.)</option>
                        <option value="Customer">🧑‍✈️ Yolcu (Müşteri)</option>
                    </select>
                </div>

                <div class="mb-4">
                    <label asp-for="Email" class="form-label text-muted fw-bold"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">📧</span>
                        <input asp-for="Email" class="form-control border-start-0" placeholder="E-posta veya pasaport numarası" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label text-muted fw-bold">Şifreniz</label>
                    <input type="password" name="Password" class="form-control border-start-0" placeholder="••••••••" required>
                </div>

                <button type="submit" class="btn btn-login w-100 mb-4">SİSTEME GİRİŞ YAP</button>

                <div class="text-center">
                    <span class="text-muted">Henüz hesabınız yok mu?</span>
                    <a href="/Home/Register" class="text-decoration-none fw-bold ms-1" style="color: #0A2342;">Hemen Kayıt Olun</a>
                </div>
            </form>
        </div>

    </div>
</div>