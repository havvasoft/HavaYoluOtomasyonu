@model IEnumerable<HavaYoluOtomasyonu.Models.Ticket>

@{
    ViewData["Title"] = "Biletlerim";
}

<div class="page-header">
    <div>
        <h1 class="h3">Biletlerim</h1>
        <p class="text-muted-small mb-0">Sisteme giriş yaptığınızda satın aldığınız biletlerinizi ve uçuş detaylarını buradan takip edebilirsiniz.</p>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-info">Henüz kayıtlı bir biletiniz bulunmamaktadır.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Bilet No</th>
                            <th>Uçuş</th>
                            <th>Rota</th>
                            <th>Koltuk</th>
                            <th>Sınıf</th>
                            <th>Check-in</th>
                            <th class="text-end">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.TicketNumber</td>
                                <td>@item.Flight?.FlightId</td>
                                <td>@(item.Flight?.Routes != null ? item.Flight.Routes.DepartureAirport?.City + " → " + item.Flight.Routes.ArrivalAirport?.City : "-")</td>
                                <td>@item.SeatNumber</td>
                                <td>@item.ClassType</td>
                                <td>
                                    @if (item.IsCheckedIn == true)
                                    {
                                        <span class="badge bg-success">Tamamlandı</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Beklemede</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-controller="Customer" asp-action="Details" asp-route-id="@item.TicketId" class="btn btn-outline-info btn-sm">Detay</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
