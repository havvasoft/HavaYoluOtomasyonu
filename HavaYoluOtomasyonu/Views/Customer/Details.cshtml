@model HavaYoluOtomasyonu.Models.Ticket

@{
    ViewData["Title"] = "Bilet Detayı";
}

<div class="page-header">
    <div>
        <h1 class="h3">Bilet Detayı</h1>
        <p class="text-muted-small mb-0">Seçtiğiniz biletle ilgili uçuş, koltuk ve ödeme bilgilerini inceleyebilirsiniz.</p>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Bilet No</dt>
            <dd class="col-sm-9">@Model.TicketNumber</dd>

            <dt class="col-sm-3">Uçuş</dt>
            <dd class="col-sm-9">@Model.Flight?.FlightId</dd>

            <dt class="col-sm-3">Rota</dt>
            <dd class="col-sm-9">@(Model.Flight?.Routes != null ? Model.Flight.Routes.DepartureAirport?.City + " → " + Model.Flight.Routes.ArrivalAirport?.City : "-")</dd>

            <dt class="col-sm-3">Koltuk</dt>
            <dd class="col-sm-9">@Model.SeatNumber</dd>

            <dt class="col-sm-3">Sınıf</dt>
            <dd class="col-sm-9">@Model.ClassType</dd>

            <dt class="col-sm-3">Check-in Durumu</dt>
            <dd class="col-sm-9">@(Model.IsCheckedIn == true ? "Tamamlandı" : "Beklemede")</dd>

            <dt class="col-sm-3">Bagaj Hakkı</dt>
            <dd class="col-sm-9">@Model.BaggageAllowance ?? 0 kg</dd>

            <dt class="col-sm-3">Yolcu</dt>
            <dd class="col-sm-9">@Model.Passenger?.FirstName @Model.Passenger?.LastName</dd>

            <dt class="col-sm-3">Bilet Tutarı</dt>
            <dd class="col-sm-9">@Model.Fare?.FareBasicCode ?? "Bilgi yok"</dd>
        </dl>
        <div class="mt-3">
            <a asp-controller="Customer" asp-action="Index" class="btn btn-outline-secondary">Geri Dön</a>
        </div>
    </div>
</div>
